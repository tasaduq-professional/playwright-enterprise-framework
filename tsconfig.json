{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "mcp/**/*.ts",
    "tests/**/*.ts",
    "**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}